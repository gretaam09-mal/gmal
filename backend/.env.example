PROVISION_ENV=development
PROVISION_DATABASE_URL=postgresql+psycopg://provision:provision@localhost:5432/provision
PROVISION_AWS_REGION=eu-west-2

# See docs/adr/0001-clerk-for-authentication.md and docs/runbooks/clerk-setup.md
PROVISION_CLERK_JWKS_URL=
PROVISION_CLERK_ISSUER=

# Signs workspace-invite links — set a real random value outside dev.
PROVISION_APP_SECRET_KEY=dev-only-insecure-secret-key-change-me

# See docs/runbooks/companies-house-setup.md
PROVISION_COMPANIES_HOUSE_API_KEY=

# See docs/runbooks/anthropic-setup.md
PROVISION_ANTHROPIC_API_KEY=

# Comma-separated emails auto-granted /admin staff access on next sign-in.
# See docs/runbooks/anthropic-setup.md "Staff access to the workbench".
PROVISION_ADMIN_EMAILS=

# Comma-separated browser origins allowed to call this API. "*" for local dev.
PROVISION_CORS_ALLOWED_ORIGINS=*
